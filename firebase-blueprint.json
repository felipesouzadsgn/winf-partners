{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the application.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User's email address" },
        "name": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["admin", "investor"], "description": "Role of the user" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "updatedAt": { "type": "number", "description": "Timestamp of last update" }
      },
      "required": ["email", "name", "role", "createdAt", "updatedAt"]
    },
    "Investment": {
      "title": "Investment",
      "description": "An investment record in the Dark Pool.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who made the investment" },
        "poolId": { "type": "string", "description": "ID of the Dark Pool" },
        "amount": { "type": "number", "description": "Investment amount" },
        "status": { "type": "string", "enum": ["pending", "active", "completed"], "description": "Status of the investment" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "updatedAt": { "type": "number", "description": "Timestamp of last update" }
      },
      "required": ["userId", "poolId", "amount", "status", "createdAt", "updatedAt"]
    },
    "Dividend": {
      "title": "Dividend",
      "description": "A dividend payout record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user receiving the dividend" },
        "investmentId": { "type": "string", "description": "ID of the associated investment" },
        "amount": { "type": "number", "description": "Dividend amount" },
        "status": { "type": "string", "enum": ["pending", "processed"], "description": "Status of the dividend payout" },
        "date": { "type": "string", "description": "Payout date (e.g., '12 Mai 2026')" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "updatedAt": { "type": "number", "description": "Timestamp of last update" }
      },
      "required": ["userId", "investmentId", "amount", "status", "date", "createdAt", "updatedAt"]
    },
    "AgentInsight": {
      "title": "Agent Insight",
      "description": "Insights and alerts generated by WINF AI for users.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "related_entity_id": { "type": "string" },
        "is_read": { "type": "boolean" },
        "created_at": { "type": "timestamp" }
      },
      "required": ["user_id", "type", "title", "content", "is_read", "created_at"]
    },
    "CoreAIChat": {
      "title": "Core AI Chat",
      "description": "Message history for the Core AI interface.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai", "system"] },
        "text": { "type": "string" },
        "created_at": { "type": "timestamp" }
      },
      "required": ["user_id", "role", "text", "created_at"]
    },
    "AIGeneration": {
      "title": "AI Generation",
      "description": "Tracks AI generated content like marketing copy.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "tool_used": { "type": "string" },
        "prompt": { "type": "string" },
        "output_url": { "type": "string" },
        "media_type": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "timestamp" }
      },
      "required": ["user_id", "tool_used", "prompt", "media_type", "created_at"]
    },
    "AgentLog": {
      "title": "Agent Log",
      "description": "Logs for Agent/Lead interactions and automation streams.",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "agentType": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "created_at": { "type": "timestamp" }
      },
      "required": ["user_id", "agentType", "action", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/investments/{investmentId}": {
      "schema": { "$ref": "#/entities/Investment" },
      "description": "Stores investment records."
    },
    "/dividends/{dividendId}": {
      "schema": { "$ref": "#/entities/Dividend" },
      "description": "Stores dividend payout records."
    },
    "/agent_insights/{insightId}": {
      "schema": { "$ref": "#/entities/AgentInsight" },
      "description": "Stores AI generated insights and alerts."
    },
    "/core_ai_chats/{chatId}": {
      "schema": { "$ref": "#/entities/CoreAIChat" },
      "description": "Stores AI chat history."
    },
    "/ai_generations/{genId}": {
      "schema": { "$ref": "#/entities/AIGeneration" },
      "description": "Stores AI generation outputs."
    },
    "/agent_logs/{logId}": {
      "schema": { "$ref": "#/entities/AgentLog" },
      "description": "Stores AI automation and interaction logs."
    }
  }
}
